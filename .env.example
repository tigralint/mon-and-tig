# ============================================================
# Lumea — Конфигурация
# ============================================================

# РЕКОМЕНДУЕТСЯ: укажите URL вашего Cloudflare Worker (прокси).
# API-ключ хранится в секретах Worker'а и не попадает в бандл.
# Пример: VITE_GEMINI_BASE_URL=https://lumea-proxy.yourname.workers.dev
VITE_GEMINI_BASE_URL=

# ТОЛЬКО ДЛЯ ЛОКАЛЬНОЙ РАЗРАБОТКИ (небезопасно для продакшена!):
# Если VITE_GEMINI_BASE_URL не указан, ключ используется напрямую.
# VITE_GEMINI_API_KEY=your_api_key_here
